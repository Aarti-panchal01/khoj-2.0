{
  "name": "khoj-backend",
  "version": "1.0.0",
  "description": "Express backend for Khoj Lost & Found",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "lint": "eslint .",
    "test": "jest --runInBand",
    "seed:universities": "node -e \"require('dotenv').config(); const connect=require('./src/config/db'); const seed=require('./src/utils/seedUniversities'); connect().then(seed).then(()=>{console.log('Done'); process.exit(0);}).catch(e=>{console.error(e); process.exit(1);});\"",
    "migrate:items": "node src/scripts/migrateItems.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.9.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.19.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.2.1",
    "firebase-admin": "^13.7.0",
    "google-auth-library": "^9.15.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.6.0",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "multer-storage-cloudinary": "^2.2.1",
    "nodemailer": "^8.0.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "fast-check": "^4.6.0",
    "jest": "^30.3.0",
    "nodemon": "^3.1.7"
  }
}
