# Server Configuration
PORT=4000
NODE_ENV=production

# MongoDB
# Use MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/khoj?retryWrites=true

# JWT — use a long random secret (e.g. openssl rand -hex 64)
# Access token expiry is 1 hour; refresh token is 7 days (HTTP-only cookie)
# Logout invalidates tokens server-side via tokenVersion
JWT_SECRET=your_super_long_random_secret_here_min_64_chars
JWT_REFRESH_SECRET=your_super_long_random_refresh_secret_min_64_chars

# CORS — set to your production frontend URL
CLIENT_ORIGIN=https://your-vercel-frontend.vercel.app

# Google Sign-In (OAuth 2.0 Client ID for Google Identity Services)
GOOGLE_CLIENT_ID=16568915138-2jm1k3462gipcmqi2u144lco5abqr0ng.apps.googleusercontent.com

# Cloudinary

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Rate limiting (optional override)
RATE_LIMIT_MAX=100

# Email / SMTP — for OTP verification emails
# Gmail example: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, use an App Password
# SendGrid example: SMTP_HOST=smtp.sendgrid.net, SMTP_PORT=587, SMTP_USER=apikey, SMTP_PASS=<api_key>
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM_NAME=Khoj Lost & Found
