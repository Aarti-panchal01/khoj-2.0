# Server Configuration
PORT=4000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/khoj

# JWT — use a long random secret (e.g. openssl rand -hex 64)
# Access token expiry is 1 hour; refresh token is 7 days (HTTP-only cookie)
# Logout invalidates tokens server-side via tokenVersion
JWT_SECRET=replace_with_a_long_random_secret
JWT_REFRESH_SECRET=replace_with_a_different_long_random_secret

# CORS — comma-separated list of allowed frontend origins
CLIENT_ORIGIN=http://localhost:5173

# Firebase Admin SDK (for verifying Firebase ID tokens from frontend)
# Get these from Firebase Console > Project Settings > Service Accounts > Generate New Private Key
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour private key here\n-----END PRIVATE KEY-----\n"

# Google Sign-In (OAuth 2.0 Client ID for Google Identity Services — same value as VITE_GOOGLE_CLIENT_ID)
# NOTE: This is now optional if using Firebase Admin SDK
GOOGLE_CLIENT_ID=

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Rate limiting (optional override)
RATE_LIMIT_MAX=100

# Email / SMTP — for OTP verification emails
# Gmail example: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, use an App Password
# SendGrid example: SMTP_HOST=smtp.sendgrid.net, SMTP_PORT=587, SMTP_USER=apikey, SMTP_PASS=<api_key>
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM_NAME=Khoj Lost & Found
